# --- Nusxa oling: .env fayl yasang va shu qiymatlarni to'ldiring ---

# Groq API kaliti — TEKIN (dunyoning hamma yeridan ishlaydi)
# console.groq.com/keys -> Create API Key
GROQ_API_KEY=gsk_...

# Telegram bot token (Telegram'da @BotFather -> /newbot)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhi...

# Sizning Telegram ID'ingiz (@userinfobot ga yozing).
# Faqat shu ID bot bilan gaplasha oladi. 0 qoldirsangiz — hamma gaplasha oladi (tavsiya etilmaydi).
OWNER_ID=0

# Model tanlovi (Groq'da tekin, tool'larni ISHONCHLI chaqiradi):
#   openai/gpt-oss-120b -> tool uchun eng ishonchli, kuchli (tavsiya)
#   openai/gpt-oss-20b  -> tezroq, yengilroq
#   qwen/qwen3-32b      -> yaxshi muqobil
# (llama-3.3-70b tool'ni ba'zan buzib yuboradi — tavsiya etilmaydi)
MODEL=openai/gpt-oss-120b

# --- Userbot: shaxsiy akkaunt (IXTIYORIY, 2-bosqich) ---
# my.telegram.org -> API development tools -> ilova yaratish
# Keyin bir marta: python setup_userbot.py
TG_API_ID=0
TG_API_HASH=

# --- Guruh moderatsiyasi (bot guruhda admin bo'lishi kerak) ---
MOD_WARN_LIMIT=2          # nechta ogohlantirishdan keyin chiqarish
MOD_TEST_MODE=0           # 1=egani ham tekshiradi (o'z akkaunt bilan sinash uchun)
MOD_VIDEO_MAX_MB=50       # shu hajmgacha video chuqur skanerlanadi
MOD_BLOCK_BIG_VIDEO=1     # 1=tekshirib bo'lmaydigan katta videolar o'chiriladi

# --- Guruh xavfsizligi ---
MOD_CAS=1                 # yangi a'zoni ma'lum spamerlar bazasidan tekshirish (bepul)
MOD_CAPTCHA=1             # yangi a'zo "Men odamman" tugmasini bosib tasdiqlaydi
MOD_CAPTCHA_SEC=60        # tasdiqlash muddati (soniya)
MOD_LINKS=1              # xavfli linklarni o'chirish + ogohlantirish
